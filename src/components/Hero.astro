---
---

<section class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden gradient-bg">
  <!-- Decorative blobs (subtle, light mode) -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-32 -right-32 w-[600px] h-[600px] rounded-full
                bg-gradient-to-br from-blue-100 to-violet-100 opacity-60 blur-3xl animate-float"></div>
    <div class="absolute -bottom-24 -left-24 w-[500px] h-[500px] rounded-full
                bg-gradient-to-tr from-cyan-100 to-blue-100 opacity-50 blur-3xl animate-float"
         style="animation-delay:3s"></div>
  </div>

  <div class="relative z-10 text-center max-w-3xl mx-auto pt-20">
    <!-- 状态标签 -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 rounded-full
                bg-white border border-border shadow-card text-sm text-text-muted
                animate-fade-up">
      <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
      开放协作 · 欢迎交流
    </div>

    <!-- 主标题 -->
    <h1 class="text-5xl sm:text-7xl font-bold leading-[1.1] tracking-tight animate-fade-up"
        style="animation-delay:0.1s">
      <span class="text-text">你好，我是</span><br/>
      <span class="gradient-text">Aswellle</span>
    </h1>

    <p class="mt-5 text-xl sm:text-2xl text-text-secondary font-light animate-fade-up"
       style="animation-delay:0.2s">
      独立开发者 · 开源爱好者 · AI 工具构建者
    </p>

    <p class="mt-4 text-base text-text-muted max-w-xl mx-auto leading-relaxed animate-fade-up"
       style="animation-delay:0.3s">
      专注于隐私优先的本地化工具，面向中文开发者生态，用代码解决真实问题。
    </p>

    <!-- CTA 按钮 -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4 animate-fade-up"
         style="animation-delay:0.4s">
      <a href="#projects"
         class="px-7 py-3 rounded-2xl text-sm font-semibold text-white
                bg-gradient-to-r from-accent to-accent-purple
                shadow-lg shadow-blue-200
                hover:shadow-blue-300 hover:-translate-y-0.5
                transition-all duration-200">
        浏览我的项目
      </a>
      <a href="#about"
         class="px-7 py-3 rounded-2xl text-sm font-semibold text-text-secondary
                bg-white border border-border shadow-card
                hover:shadow-card-hover hover:-translate-y-0.5
                transition-all duration-200">
        了解我 →
      </a>
    </div>

    <!-- 统计数字 -->
    <div class="mt-16 flex items-center justify-center gap-8 sm:gap-16 animate-fade-up"
         style="animation-delay:0.5s">
      {[
        { num: '17', label: '开源仓库' },
        { num: '5', label: '主要项目' },
        { num: '4', label: '编程语言' },
      ].map(({ num, label }) => (
        <div class="text-center">
          <div class="text-3xl font-bold gradient-text">{num}</div>
          <div class="text-xs text-text-muted mt-1">{label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- 向下滚动提示 -->
  <a href="#projects" aria-label="向下滚动"
     class="absolute bottom-8 left-1/2 -translate-x-1/2 text-text-dim hover:text-accent
            transition-colors duration-200 animate-bounce">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
    </svg>
  </a>
</section>

---
import ContactForm from './ContactForm';
---

<section id="contact" class="py-16 sm:py-24 px-5 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- 左侧文案 -->
      <div class="reveal">
        <span class="text-xs font-mono text-accent tracking-widest uppercase font-medium">联系我</span>
        <h2 class="mt-2 text-3xl font-bold text-text">一起来做点有意思的事</h2>
        <p class="mt-4 text-text-muted leading-relaxed">
          无论是项目合作、技术讨论、产品反馈，还是只是想打个招呼——都欢迎。
        </p>

        <!-- 联系方式 -->
        <div class="mt-8 space-y-3">
          <a href="https://github.com/Aswellle" target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-3 p-4 rounded-2xl bg-white border border-border shadow-card
                    hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-200">
            <div class="w-9 h-9 rounded-xl bg-bg-elevated flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-text-secondary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-text">GitHub</div>
              <div class="text-xs text-text-muted">github.com/Aswellle</div>
            </div>
            <svg class="w-4 h-4 text-text-dim ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- 响应承诺 -->
        <p class="mt-6 text-xs text-text-dim flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500" aria-hidden="true"></span>
          通常在 24-48 小时内回复
        </p>
      </div>

      <!-- 右侧表单 -->
      <div class="reveal stagger-2">
        <div class="bento-card p-8">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </div>
</section>

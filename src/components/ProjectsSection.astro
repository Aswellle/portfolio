---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
---

<section id="projects" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="reveal mb-12">
      <span class="text-xs font-mono text-accent tracking-widest uppercase">Open Source</span>
      <h2 class="mt-3 text-3xl font-bold text-text">Projects</h2>
      <p class="mt-3 text-text-muted max-w-xl">
        Tools I've built and shipped — each one solving a problem I actually had.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </div>
  </div>
</section>

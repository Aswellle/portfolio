---
const skills = [
  { label: 'Tauri + Rust', icon: '🦀' },
  { label: 'TypeScript', icon: '⬡' },
  { label: 'React / Astro', icon: '⚛' },
  { label: 'Python', icon: '🐍' },
  { label: 'AI Integration', icon: '◈' },
  { label: 'Privacy-first', icon: '🔒' },
];
---

<section id="about" class="py-24 px-6">
  <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-center">
    <div class="reveal">
      <span class="text-xs font-mono text-accent tracking-widest uppercase">About</span>
      <h2 class="mt-3 text-3xl font-bold text-text leading-snug">
        Solo builder.<br/>Privacy-first philosophy.
      </h2>
      <p class="mt-5 text-text-muted leading-relaxed">
        I build developer tools and utilities focused on the Chinese developer ecosystem —
        tools that run locally, respect privacy, and solve real workflow pain points.
      </p>
      <p class="mt-4 text-text-muted leading-relaxed">
        Most of my projects aggregate powerful AI services behind clean interfaces,
        or bring desktop-quality UX to problems usually solved with clunky web apps.
      </p>
      <a
        href="https://github.com/Aswellle"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-accent-light
               hover:text-accent transition-colors duration-200"
        aria-label="View all projects on GitHub"
      >
        View all repos on GitHub
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="reveal stagger-2 grid grid-cols-2 gap-3">
      {skills.map((skill) => (
        <div class="flex items-center gap-3 px-4 py-3 rounded-xl
                    bg-bg-surface border border-border
                    hover:border-accent/30 transition-colors duration-200">
          <span class="text-lg" aria-hidden="true">{skill.icon}</span>
          <span class="text-sm text-text-muted font-medium">{skill.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

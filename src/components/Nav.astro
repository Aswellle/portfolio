---
const navLinks = [
  { href: '#projects', label: '项目' },
  { href: '#about', label: '关于我' },
  { href: '#contact', label: '联系' },
];
---

<header class="site-header fixed top-0 inset-x-0 z-50">
  <nav class="px-5 py-3.5 flex items-center justify-between
              bg-white/90 backdrop-blur-md border-b border-border
              max-w-5xl mx-auto"
       aria-label="主导航">

    <a href="/" class="font-bold text-text tracking-tight hover:text-accent
                       transition-colors duration-200 text-lg min-h-[44px] flex items-center">
      Aswellle
    </a>

    <!-- 桌面端链接 -->
    <ul class="hidden sm:flex items-center gap-1" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href}
             class="px-3 py-2 text-sm text-text-muted rounded-lg min-h-[44px] inline-flex items-center
                    hover:text-text hover:bg-bg-elevated transition-all duration-200">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="https://github.com/Aswellle" target="_blank" rel="noopener noreferrer"
           class="ml-2 flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-lg
                  text-accent border border-accent/20 bg-accent/5 min-h-[44px]
                  hover:bg-accent/10 hover:border-accent/40 transition-all duration-200"
           aria-label="GitHub 主页">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          GitHub
        </a>
      </li>
    </ul>

    <!-- 移动端汉堡按钮 -->
    <button id="nav-toggle"
            class="sm:hidden w-11 h-11 flex flex-col items-center justify-center gap-1.5
                   rounded-xl hover:bg-bg-elevated transition-colors duration-200"
            aria-label="打开菜单" aria-expanded="false" aria-controls="nav-drawer">
      <span class="nav-bar block w-5 h-0.5 bg-text rounded-full transition-all duration-300"></span>
      <span class="nav-bar block w-5 h-0.5 bg-text rounded-full transition-all duration-300"></span>
      <span class="nav-bar block w-5 h-0.5 bg-text rounded-full transition-all duration-300"></span>
    </button>
  </nav>

  <!-- 移动端抽屉菜单 -->
  <div id="nav-drawer"
       class="sm:hidden hidden bg-white border-b border-border shadow-card-hover"
       role="dialog" aria-label="导航菜单">
    <div class="max-w-5xl mx-auto px-5 py-4 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a href={link.href}
           class="nav-link px-4 py-3.5 text-base font-medium text-text-secondary rounded-xl
                  hover:bg-bg-elevated hover:text-text transition-all duration-150 min-h-[52px]
                  flex items-center">
          {link.label}
        </a>
      ))}
      <a href="https://github.com/Aswellle" target="_blank" rel="noopener noreferrer"
         class="nav-link mt-2 px-4 py-3.5 text-base font-medium rounded-xl min-h-[52px]
                flex items-center gap-2 text-accent border border-accent/20 bg-accent/5">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
        </svg>
        GitHub 主页 ↗
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('nav-drawer');

  function openMenu() {
    drawer?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.classList.add('nav-open');
    // Animate bars to X
    const bars = toggle?.querySelectorAll('.nav-bar');
    if (bars) {
      (bars[0] as HTMLElement).style.transform = 'translateY(8px) rotate(45deg)';
      (bars[1] as HTMLElement).style.opacity = '0';
      (bars[2] as HTMLElement).style.transform = 'translateY(-8px) rotate(-45deg)';
    }
  }

  function closeMenu() {
    drawer?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('nav-open');
    const bars = toggle?.querySelectorAll('.nav-bar');
    if (bars) {
      (bars[0] as HTMLElement).style.transform = '';
      (bars[1] as HTMLElement).style.opacity = '';
      (bars[2] as HTMLElement).style.transform = '';
    }
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMenu() : openMenu();
  });

  // Close on link tap
  drawer?.querySelectorAll('.nav-link').forEach(a => a.addEventListener('click', closeMenu));

  // Close on outside tap
  document.addEventListener('click', (e) => {
    if (toggle?.getAttribute('aria-expanded') === 'true'
        && !toggle.contains(e.target as Node)
        && !drawer?.contains(e.target as Node)) {
      closeMenu();
    }
  });
</script>

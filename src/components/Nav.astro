---
const navLinks = [
  { href: '#projects', label: 'Projects' },
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed top-0 inset-x-0 z-50">
  <nav
    class="mx-auto max-w-5xl px-6 py-4 flex items-center justify-between
           backdrop-blur-md bg-bg/70 border-b border-border"
    aria-label="Main navigation"
  >
    <a href="/" class="font-semibold text-text tracking-tight hover:text-accent-light transition-colors duration-200">
      Aswellle
    </a>
    <ul class="flex items-center gap-1" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="px-3 py-1.5 text-sm text-text-muted rounded-md
                   hover:text-text hover:bg-bg-elevated
                   transition-all duration-200 focus-visible:ring-2 focus-visible:ring-accent"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://github.com/Aswellle"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-3 px-3 py-1.5 text-sm font-medium rounded-md
                 bg-accent/10 text-accent-light border border-accent/20
                 hover:bg-accent/20 hover:border-accent/40
                 transition-all duration-200"
          aria-label="GitHub profile"
        >
          GitHub ↗
        </a>
      </li>
    </ul>
  </nav>
</header>

---
import AdminApp from '../../components/admin/AdminApp';
import '../../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>管理后台 — Aswellle</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Noto Sans SC', system-ui, sans-serif; background: #f9fafb; }
      :focus-visible { outline: 2px solid #2563eb; outline-offset: 2px; border-radius: 6px; }
      html, body, #root { height: 100%; overflow: hidden; }
      .admin-root { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
      .admin-body { display: flex; flex: 1 1 0; min-height: 0; overflow: hidden; }
      .admin-sidebar { display: none; }
      .admin-main { display: flex; flex-direction: column; flex: 1 1 0; min-height: 0; overflow: hidden; }
      .msg-panel { display: flex; flex-direction: column; flex: 1 1 0; min-height: 0; overflow: hidden; }
      .msg-toolbar { flex-shrink: 0; }
      .msg-content { display: flex; flex: 1 1 0; min-height: 0; }
      .msg-list { display: flex; flex-direction: column; width: 20rem; flex-shrink: 0; overflow-y: auto; border-right: 1px solid #e4e4e7; background: #fff; }
      .msg-detail { display: flex; flex-direction: column; flex: 1 1 0; min-width: 0; min-height: 0; }
      .msg-detail-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; }
      .msg-detail-header { flex-shrink: 0; }
      .msg-detail-body { flex: 1 1 0; min-height: 0; overflow-y: auto; }
      @media (min-width: 768px) {
        .admin-sidebar { display: block; }
        .msg-list { display: flex !important; }
        .msg-detail { display: flex !important; }
      }
    </style>
  </head>
  <body>
    <AdminApp client:load />
  </body>
</html>
